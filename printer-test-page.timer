# systemd user timer that runs the test page once a week
# Install alongside printer-test-page.service (see that file for instructions).

[Unit]
Description=Weekly printer test page to keep heads from clogging

[Timer]
# See man systemd.time
# Run every Monday at 8am
OnCalendar=Mon *-*-* 08:00:00
Persistent=true

[Install]
WantedBy=timers.target

